# =============================================
# natalia_bot - Konfiguration
# Kopiere diese Datei als .env und fuelle aus
# =============================================

# --- Pflichtfelder ---
TELEGRAM_BOT_TOKEN=dein_token_hier
AUTHORIZED_USER_ID=111111111
ADMIN_USER_ID=222222222

# --- Support-Modus ---
SUPPORT_CODEWORD=hilfe123

# --- E-Mail-Alerts (optional) ---
# Wenn EMAIL_ENABLED=true, bekommst du eine E-Mail wenn Natalia hilfe123 tippt
EMAIL_ENABLED=false
EMAIL_FROM=dein@gmail.com
EMAIL_TO=dein@gmail.com
EMAIL_PASSWORD=gmail_app_passwort
EMAIL_SMTP=smtp.gmail.com
EMAIL_PORT=587

# --- KI-Modell ---
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# --- STT ---
STT_PROVIDER=mock
WHISPER_MODEL=small

# --- TTS ---
TTS_PROVIDER=mock
ELEVENLABS_API_KEY=
VOICE_ID_VITALI=
VOICE_ID_DERING=
VOICE_ID_IMPERATOR=

# --- Datenbank ---
DATABASE_PATH=data/natalia_bot.db
LOG_FILE=logs/bot.log

# --- Tagliche Erinnerung ---
DAILY_REMINDER_TIME=09:00
TIMEZONE=Europe/Berlin

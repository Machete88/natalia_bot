# ============================================================
# natalia_bot - Umgebungsvariablen
# Kopiere diese Datei nach .env und trage deine Werte ein.
# WICHTIG: .env niemals in Git einchecken!
# ============================================================

# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
AUTHORIZED_USER_ID=123456789
ADMIN_USER_ID=123456789

# === LLM (OpenRouter empfohlen) ===
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-or-v1-YOUR_KEY_HERE
OPENAI_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=x-ai/grok-3-fast

# === STT (Spracherkennung) ===
# mock     = keine STT, Text wird simuliert
# whisper_local = lokales Whisper-Modell (langsam aber gratis)
STT_PROVIDER=mock
WHISPER_MODEL=small

# === TTS (Sprachsynthese) ===
# mock       = keine TTS, kein Audio
# elevenlabs = ElevenLabs API (beste Qualitaet)
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=sk_YOUR_KEY_HERE
VOICE_ID_VITALI=YOUR_VOICE_ID_FOR_VITALI
VOICE_ID_DERING=YOUR_VOICE_ID_FOR_DERING
VOICE_ID_IMPERATOR=YOUR_VOICE_ID_FOR_IMPERATOR

# === DATENBANK / LOGS ===
DATABASE_PATH=data/natalia_bot.db
LOG_FILE=logs/bot.log

# === ERINNERUNGEN (optional) ===
# Format: HH:MM (24h), Zeitzone Europe/Berlin
DAILY_REMINDER_TIME=09:00
TIMEZONE=Europe/Berlin

# =============================================
# natalia_bot - Konfiguration
# Kopiere diese Datei als .env und fuelle aus
# =============================================

# --- Pflichtfelder ---
TELEGRAM_BOT_TOKEN=dein_telegram_bot_token
AUTHORIZED_USER_ID=deine_telegram_user_id
ADMIN_USER_ID=deine_admin_telegram_id

# --- KI-Modell (OpenAI oder OpenRouter) ---
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-or-v1-...
OPENAI_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=x-ai/grok-4.1-fast

# --- Spracherkennung (STT) ---
# mock = deaktiviert, whisper_local = lokal
STT_PROVIDER=whisper_local
WHISPER_MODEL=small

# --- Sprachausgabe (TTS) ---
# mock = deaktiviert, elevenlabs = ElevenLabs API
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=sk_...
VOICE_ID_VITALI=rQOBu7YxCDxGiFdTm28w
VOICE_ID_DERING=KpX1OoMT6Br64YtIpgRI
VOICE_ID_IMPERATOR=zWSsRd3J6WyZFl12aGMB

# --- Support-Modus ---
SUPPORT_CODEWORD=hilfe123

# --- E-Mail-Alerts (optional) ---
EMAIL_ENABLED=false
EMAIL_FROM=dein@gmail.com
EMAIL_TO=dein@gmail.com
EMAIL_PASSWORD=gmail_app_passwort
EMAIL_SMTP=smtp.gmail.com
EMAIL_PORT=587

# --- Zeitzone & Erinnerung ---
USER_TIMEZONE=Europe/Berlin
TIMEZONE=Europe/Berlin
DAILY_REMINDER_TIME=09:00

# --- Datenbank & Logs ---
DATABASE_PATH=data/natalia.db
LOG_FILE=logs/natalia_bot.log
AUDIO_TEMP_DIR=media/audio
AUDIO_CACHE_DIR=media/cache

# --- Debug ---
DEBUG_MODE=false

# =============================================
# natalia_bot - Konfiguration
# Kopiere diese Datei als .env und fuelle aus
# =============================================

# --- Pflichtfelder ---
TELEGRAM_BOT_TOKEN=dein_token_hier

# Telegram User-ID von Natalia (nur sie darf den Bot nutzen)
AUTHORIZED_USER_ID=111111111

# Deine eigene Telegram User-ID (Admin = du)
ADMIN_USER_ID=222222222

# --- Support-Modus ---
# Natalia tippt dieses Wort -> du wirst in den Chat eingebunden
# Tipp: etwas Unaufaelliges waehlen, z.B. ein russisches Wort
SUPPORT_CODEWORD=hilfe123

# --- KI-Modell ---
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
# Optional: OpenRouter oder andere OpenAI-kompatible APIs
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=gpt-4o-mini

# --- Sprache-zu-Text (STT) ---
# mock = deaktiviert | whisper_local = lokales Whisper
STT_PROVIDER=mock
WHISPER_MODEL=small

# --- Text-zu-Sprache (TTS) ---
# mock = deaktiviert | elevenlabs = ElevenLabs API
TTS_PROVIDER=mock
ELEVENLABS_API_KEY=
VOICE_ID_VITALI=
VOICE_ID_DERING=
VOICE_ID_IMPERATOR=

# --- Datenbank ---
DATABASE_PATH=data/natalia_bot.db

# --- Logs ---
LOG_FILE=logs/bot.log

# --- Tagliche Erinnerung ---
DAILY_REMINDER_TIME=09:00
TIMEZONE=Europe/Berlin
